############################################
# MINIMO PARA COMECAR
############################################
# Obrigatorio
DISCORD_TOKEN=seu_token_aqui
# Backend padrao de desenvolvimento
BOT_REPOSITORY_BACKEND=sqlite
# Para Postgres (recomendado em producao):
# BOT_REPOSITORY_BACKEND=postgres
# POSTGRES_DSN=postgresql://usuario:senha@host:5432/botmusica
# POSTGRES_PASSWORD=troque_esta_senha_muito_forte
# Imagem imutavel para deploy no k8s (evite :latest)
# BOT_IMAGE=botmusica:2026-02-28

############################################
# CORE
############################################
# Opcional: use o ID de um servidor para sincronizar comandos slash instantaneamente
TEST_GUILD_ID=
# Segundos de inatividade para auto-desconectar quando fila acaba
IDLE_DISCONNECT_SECONDS=300
# Timeout maximo (segundos) para conectar no canal de voz (Lavalink/FFmpeg)
VOICE_CONNECT_TIMEOUT_SECONDS=8
# Caminho do banco SQLite de configuracoes por servidor
BOT_DB_PATH=botmusica.db
# Limite de musicas pendentes por servidor
MAX_QUEUE_SIZE=100
# Opcional: limite de musicas pendentes por usuario (0 desliga)
# MAX_USER_QUEUE_ITEMS=20
# Limite de faixas importadas por comando /play quando receber playlist
MAX_PLAYLIST_IMPORT=100
# Cooldown (segundos) para /play e /search por usuario
PLAY_COOLDOWN_SECONDS=3

############################################
# RATE LIMIT / BUSCA / CACHE
############################################
# Opcional: janela e limite de requests /play(/playnext) por usuario
# PLAY_USER_WINDOW_SECONDS=10
# PLAY_USER_MAX_REQUESTS=4
# Opcional: janela e limite de requests /play(/playnext) por servidor
# PLAY_GUILD_WINDOW_SECONDS=10
# PLAY_GUILD_MAX_REQUESTS=10
# Opcional: janela e limite por canal de voz (anti-spam em canais grandes)
# PLAY_CHANNEL_WINDOW_SECONDS=10
# PLAY_CHANNEL_MAX_REQUESTS=8
# Opcional: rate limit dedicado para /search
# SEARCH_USER_WINDOW_SECONDS=10
# SEARCH_USER_MAX_REQUESTS=6
# SEARCH_GUILD_WINDOW_SECONDS=10
# SEARCH_GUILD_MAX_REQUESTS=14
# Opcional: rate limit dedicado para /playlist_load
# PLAYLIST_LOAD_USER_WINDOW_SECONDS=15
# PLAYLIST_LOAD_USER_MAX_REQUESTS=2
# PLAYLIST_LOAD_GUILD_WINDOW_SECONDS=15
# PLAYLIST_LOAD_GUILD_MAX_REQUESTS=5
# Opcional: modo estrito para conversao Spotify -> busca (recomendado)
# SPOTIFY_STRICT_MATCH=true
# Opcional: threshold de similaridade (0.0 a 1.0) no modo estrito
# SPOTIFY_MATCH_THRESHOLD=0.55
# Opcional: quantidade de resultados no /search (menor = mais rapido)
# SEARCH_RESULTS_LIMIT=3
# Opcional: quantidade de sugestoes no autocomplete de /play e /search
# SEARCH_AUTOCOMPLETE_LIMIT=10
# Opcional: cache em segundos para buscas repetidas no /search
# SEARCH_CACHE_TTL_SECONDS=60
# Opcional: aceitar resultado stale por ate N segundos (responde instantaneo e revalida)
# SEARCH_CACHE_STALE_TTL_SECONDS=600
# Opcional: total de entradas no cache de /search
# SEARCH_CACHE_MAX_ENTRIES=256
# Opcional: timeout duro da busca (/search)
# SEARCH_TIMEOUT_SECONDS=3.5
# Opcional: pipeline de busca por etapas (cache -> lavalink -> resolver)
# SEARCH_PIPELINE_CACHE_TIMEOUT_SECONDS=0.12
# SEARCH_PIPELINE_LAVALINK_TIMEOUT_SECONDS=1.6
# Opcional: busca adaptativa (reduz limit quando latencia sobe)
# ADAPTIVE_SEARCH_ENABLED=true
# ADAPTIVE_SEARCH_LATENCY_MS=2000
# ADAPTIVE_SEARCH_MIN_LIMIT=2
# Opcional: backpressure global/per-provider no yt-dlp
# YTDLP_GLOBAL_CONCURRENCY=6
# YTDLP_PROVIDER_CONCURRENCY=3
# Opcional: rejeitar /play de playlist quando backlog interno estiver alto
# PLAY_BACKPRESSURE_THRESHOLD_RATIO=0.75
# PLAY_BACKPRESSURE_ACTIVE_IMPORTS=4
# Opcional: flush em lote de eventos/estatisticas para reduzir I/O
# BATCH_WRITE_INTERVAL_SECONDS=0.35
# BATCH_WRITE_MAX_ITEMS=40
# Opcional: prewarm de cache baseado no historico de playback
# SEARCH_PREWARM_ENABLED=true
# SEARCH_PREWARM_QUERY_COUNT=3
# Opcional: pre-carrega top queries no startup (0 desliga)
# SEARCH_STARTUP_WARMUP_QUERIES=20
# Opcional: cache de ranking de autocomplete em memoria (segundos)
# AUTOCOMPLETE_RANK_CACHE_TTL_SECONDS=45

############################################
# UX (MENSAGENS / NOWPLAYING)
############################################
# Opcional: auto remover mensagens publicas apos N segundos (0 desativa)
# PUBLIC_MESSAGE_DELETE_AFTER_SECONDS=3
# Opcional: comandos que NAO devem ser auto removidos (separados por virgula)
# AUTO_DELETE_EXEMPT_COMMANDS=help,nowplaying,metrics,diagnostics,diagnostico,settings,cache,queue_events
# Opcional: cooldown de botoes no painel nowplaying
# NOWPLAYING_BUTTON_COOLDOWN_SECONDS=1.25
# Opcional: estrategia de reconexao de voz com backoff + jitter
# VOICE_RECONNECT_ATTEMPTS=4
# VOICE_RECONNECT_BASE_DELAY_SECONDS=0.35
# VOICE_RECONNECT_MAX_DELAY_SECONDS=3.5
# VOICE_RECONNECT_JITTER_RATIO=0.25
# Opcional: cache DNS para conexao Lavalink
# DNS_CACHE_TTL_SECONDS=300
# DNS_CACHE_MAX_ENTRIES=128
# Opcional: painel nowplaying fixado automaticamente (pin)
# NOWPLAYING_AUTO_PIN=false
# Opcional: ao trocar de faixa, recria a msg nowplaying para ficar no fim do chat
# NOWPLAYING_REPOST_ON_TRACK_CHANGE=true
# Control Room: restringe /play,/playnext,/search ao canal da central
# CONTROL_ROOM_RESTRICT_MUSIC_COMMANDS=false
# Control Room: trava botoes para o operador da central (admins sempre bypass)
# CONTROL_ROOM_LOCK_OPERATOR_ENABLED=true
# Intervalo de refresh automatico do embed da central (segundos)
# CONTROL_ROOM_STATUS_INTERVAL_SECONDS=7
# Healthcheck HTTP do bot (bom para docker/k8s)
# BOT_HEALTHCHECK_ENABLED=true
# BOT_HEALTHCHECK_HOST=0.0.0.0
# BOT_HEALTHCHECK_PORT=8090

############################################
# AUTOPLAY / SPOTIFY / QUALIDADE DE AUDIO
############################################
# Opcional: quantidade de faixas recentes usadas como contexto do autoplay
# AUTOPLAY_HISTORY_SIZE=25
# Opcional: quantidade de candidatos por consulta no autoplay
# AUTOPLAY_SEARCH_LIMIT=6
# Opcional: numero maximo de consultas por rodada de autoplay
# AUTOPLAY_MAX_QUERIES=4
# Opcional: cache de metadados Spotify oEmbed (segundos)
# SPOTIFY_META_CACHE_TTL_SECONDS=900
# Opcional: limite de entradas no cache Spotify oEmbed
# SPOTIFY_META_CACHE_MAX_ENTRIES=256
# Opcional: candidatos avaliados ao converter Spotify -> busca (menor = mais rapido)
# SPOTIFY_CANDIDATE_LIMIT=3
# Opcional: modo de extracao mais agressivo/rapido no yt-dlp
# MUSIC_FAST_MODE=true
# Opcional: pipeline de audio de maior qualidade (resampler soxr)
# MUSIC_HQ_AUDIO=true

############################################
# PLAYLIST IMPORT / RESILIENCIA
############################################
# Opcional: fila incremental para playlists grandes (responde mais rapido)
# PLAYLIST_INCREMENTAL_ENABLED=true
# Quantas faixas entram imediatamente antes do background
# PLAYLIST_INITIAL_ENQUEUE=10
# Quantas faixas por lote no background
# PLAYLIST_INCREMENTAL_CHUNK_SIZE=20
# Delay entre lotes de importacao incremental (segundos)
# PLAYLIST_INCREMENTAL_CHUNK_DELAY_SECONDS=0.15
# A partir deste tamanho, /play responde ACK imediato e processa em job background
# PLAYLIST_BATCH_ACK_THRESHOLD=80
# Opcional: snapshot periodico do estado (ticks do health worker ~15s cada)
# STATE_SNAPSHOT_INTERVAL_TICKS=6
# Circuit breaker para extracao/busca (evita timeout em cascata quando provider cai)
# PROVIDER_FAILURE_THRESHOLD=5
# PROVIDER_RECOVERY_SECONDS=20
# PROVIDER_HALF_OPEN_MAX_CALLS=1

############################################
# MODERACAO / PAINEL WEB / OPUS
############################################
# Opcional: duracao maxima permitida por faixa (0 desliga)
# MAX_TRACK_DURATION_SECONDS=0
# Opcional: whitelist de dominios (se definido, so estes passam)
# DOMAIN_WHITELIST=youtube.com,youtu.be,open.spotify.com
# Opcional: blacklist de dominios (sempre bloqueados)
# DOMAIN_BLACKLIST=example.com
# Opcional: habilita painel web read-only
# WEB_PANEL_ENABLED=false
# WEB_PANEL_HOST=127.0.0.1
# WEB_PANEL_PORT=8080
# Fase de migracao: mantenha true por 1 release (deprecated) e depois troque para false
# para remover comandos slash administrativos.
# ADMIN_SLASH_ENABLED=true
# Opcional: habilita acoes write no painel web com token admin (recomendado >= 32 chars)
# WEB_PANEL_ADMIN_TOKEN=troque_este_token_longo_e_aleatorio
# OAuth2 Discord para login no painel (RBAC):
# WEB_PANEL_DISCORD_CLIENT_ID=
# WEB_PANEL_DISCORD_CLIENT_SECRET=
# WEB_PANEL_DISCORD_REDIRECT_URI=http://127.0.0.1:8080/auth/callback
# WEB_PANEL_SESSION_SECRET=troque_para_um_valor_longo_e_aleatorio  # recomendado >= 32 chars
# WEB_PANEL_ADMIN_USER_IDS=123456789012345678,987654321098765432
# WEB_PANEL_DJ_USER_IDS=222222222222222222,333333333333333333
# Opcional: caminho absoluto da libopus (se o carregamento automatico falhar)
# OPUS_LIBRARY=/opt/homebrew/opt/opus/lib/libopus.0.dylib

############################################
# YT-DLP
############################################
# Opcional: runtime JS para yt-dlp (ex: deno ou node)
# Local macOS (brew): YTDLP_JS_RUNTIME=deno:/opt/homebrew/bin/deno
# Docker/K8s (imagem com node): YTDLP_JS_RUNTIME=node:/usr/bin/node
# Opcional: remote components do yt-dlp para solver JS (recomendado: ejs:github)
# YTDLP_REMOTE_COMPONENTS=ejs:github
# Opcional: arquivo de cookies exportado (Netscape format) para YouTube
# YTDLP_COOKIES_FILE=/caminho/para/cookies.txt
# Opcional: ler cookies direto do navegador (chrome, firefox, safari, brave)
# YTDLP_COOKIES_FROM_BROWSER=chrome
# Opcional: cache de extracao do yt-dlp (segundos)
# YTDLP_CACHE_SECONDS=600
# Opcional: cache de URL de stream (segundos)
# YTDLP_STREAM_CACHE_SECONDS=1800
# Opcional: limite de entradas nos caches
# YTDLP_CACHE_MAX_ENTRIES=512
# Opcional: worker pool para extracao (fila interna)
# YTDLP_WORKER_CONCURRENCY=3
# YTDLP_WORKER_QUEUE_SIZE=128

############################################
# LAVALINK (QUANDO HABILITADO)
############################################
# Opcional: parametros de Lavalink (infra pronta em Docker/K8s)
# LAVALINK_ENABLED=false
# LAVALINK_HOST=lavalink
# LAVALINK_PORT=2333
# LAVALINK_PASSWORD=youshallnotpass
# Opcional: tentativas de conexao inicial no Lavalink com backoff
# LAVALINK_CONNECT_ATTEMPTS=8
# LAVALINK_CONNECT_BASE_DELAY_SECONDS=1.5
# Opcional: pausa (segundos) para novas tentativas de voz via Lavalink apos timeout
# LAVALINK_VOICE_TIMEOUT_COOLDOWN_SECONDS=300
# Opcional: pre-resolve Lavalink das proximas faixas
# PREFETCH_LAVALINK_RESOLVE_COUNT=2
# Opcional: retencao diaria dedicada
# RETENTION_DAILY_SECONDS=86400
# RETENTION_QUEUE_EVENTS_MAX_ROWS=2000

############################################
# FEATURE FLAGS / PROFILER / ALERTAS
############################################
# Feature flags (ligar/desligar blocos principais)
# FEATURE_PLAYLIST_JOBS_ENABLED=true
# FEATURE_PLAY_PROGRESS_UPDATES=true
# FEATURE_EXTRACTION_BACKPRESSURE_ENABLED=true
# FEATURE_RECONNECT_STRATEGY_ENABLED=true
# FEATURE_COMMAND_SERVICE_ENABLED=true
# FEATURE_NOWPLAYING_COMPACT_ENABLED=true
# Opcional: profiler leve (amostragem de logs)
# PROFILER_SAMPLE_RATIO=0.03
# RETENTION_SEARCH_CACHE_MAX_AGE_SECONDS=7200
# Opcional: smart prefetch de próximas faixas
# SMART_PREFETCH_COUNT=2
# Opcional: alertas de saude em canal Discord (ID do canal)
# HEALTH_ALERT_CHANNEL_ID=0
# HEALTH_ALERT_COOLDOWN_SECONDS=180
# HEALTH_ALERT_LATENCY_MS_THRESHOLD=2500
